; Engine configuration file.
; Generated by GenieEngine — edits are welcome, Godot also rewrites this file.
config_version=5

[application]

; No engine splash — the game boots straight into its first scene on black.
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/name="Flappy Bird"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.7")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1152
window/size/viewport_height=648
; canvas_items stretch keeps the game readable at any size — important for
; GenieEngine's embedded game view, which can be resized freely.
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
; Required for macOS/mobile exports (arm64 needs ETC2/ASTC texture import).
textures/vram_compression/import_etc2_astc=true
